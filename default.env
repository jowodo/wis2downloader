LOG_LEVEL=DEBUG

FLASK_SECRET_KEY="dev"

DATA_PATH=/data

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TTL_SECONDS=3600
REDIS_MESSAGE_LOCK=300

# comma seperated list of global caches to exclude
GC_EXCLUDE=wis2.ncm.gov.sa