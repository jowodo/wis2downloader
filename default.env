LOG_LEVEL=INFO

FLASK_SECRET_KEY="o89uzvf!-."
FLASK_DEBUG=true

# Public base URL of the deployment (used to build browser-facing URLs)
WIS2DOWNLOADER_BASE_URL=http://localhost

# Traefik-routed service URLs:

# SUBSCRIPTION_MANAGER_URL is browser-facing, so it derives from the public WIS2DOWNLOADER_BASE_URL
WIS2DOWNLOADER_SUBSCRIPTION_MANAGER_URL=${WIS2DOWNLOADER_BASE_URL}/api
WIS2DOWNLOADER_GRAFANA_URL=${WIS2DOWNLOADER_BASE_URL}/grafana

HOST_DATA_PATH=./downloads
CONTAINER_DATA_PATH=/data

# Default retention period in days
DOWNLOAD_RETENTION_PERIOD=30

# REDIS config
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TTL_SECONDS=3600
REDIS_MESSAGE_LOCK=300
REDIS_PASSWORD="n3v9.!+3f"

CELERY_BACKEND_DB=0
CELERY_RESULT_DB=1
SCHEDULER_BACKEND_DB=2
SCHEDULER_RESULT_DB=3
